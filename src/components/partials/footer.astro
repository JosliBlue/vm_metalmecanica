---
import { Icon } from 'astro-icon/components';

const devLink = { icon: 'lucide:github', href: 'https://github.com/josliblue', label: 'GitHub' };

const currentYear = new Date().getFullYear();
---

<footer class="w-full border-t border-(--primary)/20 bg-(--surface-darker) py-2 md:py-6">
    <div class="max-w-7xl mx-auto">
        <div class="flex flex-col md:flex-row justify-between items-center gap-4">
            <!-- Desarrollador info -->
            <div class="flex items-center gap-2 text-sm text-gray-400">
                <span>Desarrollado por</span>
                <a
                    href="https://github.com/josliblue"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-(--primary) hover:text-white font-bold transition-colors no-underline"
                >
                    josliblue dev
                </a>
                <span class="text-gray-600">© {currentYear}</span>
            </div>

            <!-- Social link -->
            <a
                href={devLink.href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={devLink.label}
                class="size-8 rounded-full bg-(--surface) flex items-center justify-center text-gray-400 hover:bg-(--primary) hover:text-white transition-all duration-200"
            >
                <Icon name={devLink.icon} class="size-4" />
            </a>
        </div>
    </div>
</footer>
