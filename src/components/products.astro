---
import ProductCard from '@/components/partials/product-card.astro';
import img1 from '@/assets/products/puerta.webp';
import img2 from '@/assets/products/reja.webp';
import img3 from '@/assets/products/estructura.webp';
import img4 from '@/assets/products/ventana.webp';

const productsData = {
    badge: 'Nuestro Catálogo',
    title: 'Productos en Metal',
    description: 'Fabricación y diseño de estructuras metálicas para cada necesidad.',
};

const productCategories = [
    {
        icon: 'lucide:door-open',
        title: 'Puertas',
        items: ['Puertas metálicas','Puertas mixtas(madera-metal)'],
        image: img1,
    },
    {
        icon: 'lucide:shield',
        title: 'Rejas',
        items: ['Rejas fijas','Protección para ventanas y puertas'],
        image: img2,
    },
    {
        icon: 'lucide:columns',
        title: 'Estructuras',
        items: ['Estructuras metálicas', 'Cerramientos', 'Techos metálicos'],
        image: img3,
    },
    {
        icon: 'lucide:frame',
        title: 'Ventanales & Marcos',
        items: ['Ventanas metálicas', 'Marcos estructurales'],
        image: img4,
    },
];
---

<section class="w-full py-16 md:py-20">
    <div class="w-full flex justify-center px-4 md:px-6 lg:p-8">
        <div class="w-full max-w-7xl flex flex-col gap-12">
            <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
                <div class="flex flex-col gap-2">
                    <span
                        class="text-(--primary) font-bold tracking-wider uppercase text-base md:text-sm"
                    >
                        {productsData.badge}
                    </span>
                    <h2 class="text-white text-4xl md:text-4xl font-bold leading-tight">
                        {productsData.title}
                    </h2>
                </div>
                <p class="text-gray-400 max-w-md text-base md:text-base">
                    {productsData.description}
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                {productCategories.map((category) => <ProductCard {...category} />)}
            </div>
        </div>
    </div>
</section>
