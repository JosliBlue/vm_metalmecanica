---
import { Icon } from 'astro-icon/components';

const contactData = {
    title: 'Visita Nuestro Taller',
    subtitle:
        'Ubicados en el corazón del distrito industrial, listos para atender toda el área metropolitana.',
    mapImage: '/img_carousel/img1.webp',
    formTitle: 'Solicita una Cotización',
    formSubtitle: 'Completa el formulario y te responderemos en menos de 24 horas.',
};

const contactInfo = [
    {
        icon: 'lucide:phone',
        title: 'Teléfono',
        info: '+1 (555) 123-4567',
        extra: 'Emergencias 24/7',
    },
    {
        icon: 'lucide:mail',
        title: 'Email',
        info: 'servicio@vmmetalmecanica.com',
    },
    {
        icon: 'lucide:clock',
        title: 'Horarios',
        info: 'Lun-Vie: 8am - 6pm',
        extra: 'Sáb: 9am - 2pm',
    },
    {
        icon: 'lucide:shield-check',
        title: 'Licencia',
        info: 'Lic #987654321',
        extra: 'Con Seguro y Garantía',
    },
];
---

<section class="w-full bg-(--surface-darker) py-15">
    <div class="w-full flex justify-center px-4 md:px-6 lg:p-8">
        <div class="w-full max-w-7xl">
            <div class="mb-8">
                <h2 class="text-white text-3xl md:text-4xl font-bold mb-4">
                    {contactData.title}
                </h2>
                <p class="text-gray-400 text-sm md:text-base">
                    {contactData.subtitle}
                </p>
            </div>

            <div class="grid lg:grid-cols-2 gap-12">
                <div class="flex flex-col gap-8">
                    <div class="w-full h-64 bg-gray-800 rounded-2xl overflow-hidden">
                        <iframe
                            src="https://www.google.com/maps/embed?pb=!1m17!1m12!1m3!1d1934.8100337221547!2d-78.64239719002339!3d-1.2817527045675063!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m2!1m1!2zMcKwMTYnNTQuNSJTIDc4wrAzOCczMi40Ilc!5e1!3m2!1ses-419!2sec!4v1766792647557!5m2!1ses-419!2sec"
                            loading="lazy"
                            referrerpolicy="no-referrer-when-downgrade"
                            title="Ubicación del taller"
                            class="w-full h-full border-none"
                        >
                        </iframe>
                    </div>
                </div>

                <div class="grid sm:grid-cols-2 gap-6">
                    {
                        contactInfo.map((item) => (
                            <div class="flex items-start gap-4">
                                <div class="bg-(--card-background) p-3 rounded-full text-(--primary) shrink-0">
                                    <Icon name={item.icon} class="size-5" />
                                </div>
                                <div class="flex-1">
                                    <h4 class="text-white text-base font-bold mb-1">
                                        {item.title}
                                    </h4>
                                    <p class="text-gray-400 text-sm mt-1">{item.info}</p>
                                    {item.extra && (
                                        <p class="text-(--primary) text-xs font-bold mt-1">
                                            {item.extra}
                                        </p>
                                    )}
                                </div>
                            </div>
                        ))
                    }
                </div>
            </div>
        </div>
    </div>
</section>
