---
interface Props {
    images: Array<{
        src: string;
        title?: string;
        description?: string;
    }>;
}

const { images } = Astro.props;
---

<!-- Slider -->
<div class="px-4 sm:px-6 lg:px-8">
    <div
        data-hs-carousel='{
        "loadingClasses": "opacity-0",
        "dotsItemClasses": "hs-carousel-active:bg-red-700 size-3 border border-gray-400 rounded-full cursor-pointer",
        "isAutoPlay": true
      }'
        class="relative"
    >
        <div class="hs-carousel relative overflow-hidden w-full h-120 md:h-[80dvh] rounded-2xl">
            <div
                class="hs-carousel-body absolute top-0 bottom-0 start-0 flex flex-nowrap transition-transform duration-700 opacity-0"
            >
                {
                    images.map((image) => (
                        <div class="hs-carousel-slide">
                            <div
                                class="relative h-full flex flex-col bg-cover bg-center bg-no-repeat rounded-2xl"
                                style={`background-image: url('${image.src}')`}
                            >
                                <div class="absolute inset-0 bg-linear-to-t from-black via-black/50 to-transparent rounded-2xl" />
                                {(image.title || image.description) && (
                                    <div class="relative mt-auto w-2/3 md:w-1/3  ps-5 pb-10 md:ps-10 md:pb-20 z-10">
                                        {image.title && (
                                            <h1 class="text-5xl lg:text-7xl mb-7 font-extrabold">
                                                {image.title}
                                            </h1>
                                        )}
                                        {image.description && (
                                            <p class="text-lg md:text-2xl">{image.description}</p>
                                        )}
                                    </div>
                                )}
                            </div>
                        </div>
                    ))
                }
            </div>
        </div>
    </div>
</div>
<!-- End Slider -->
